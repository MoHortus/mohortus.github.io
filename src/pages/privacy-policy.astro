---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

const title = 'Apps Privacy Policy — ' + SITE_TITLE;
const description = 'Privacy policy for MoHortus Android apps.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.policy-section {
				margin-bottom: 3rem;
			}
			.policy-section h2 {
				margin-bottom: 1rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Apps Privacy Policy</h1>

			<div class="policy-section">
				<h2>3solaris Stupid Game</h2>
				<p>
					App is not programmed to collect any personally identifiable information.
					All data created by you is stored on your device only, and can be simply erased
					by clearing the app's data or uninstalling it.
				</p>
				<p>
					Only data that could be gathered is by Google (paying for in app product) or
					Google Admob for showing ads. Please read their Privacy policy of Google In App
					Purchase and Google Admob for details.
				</p>
				<p>
					If you find any security vulnerability that has been inadvertently caused by us,
					or have any question regarding how the app protects your privacy, please send us
					an email and we will surely try to fix it/help you.
				</p>
			</div>

			<div class="policy-section">
				<h2>Radarska Padavine Dež / Radar SI / Regenradar DE</h2>
				<p>
					App is not programmed to collect any personally identifiable information.
					All data (app preferences like theme, etc. and alarms) created by you is stored
					on your device only, and can be simply erased by clearing the app's data or
					uninstalling it.
				</p>
				<p>
					Only data that could be gathered is by Google (paying for in app product) or
					Google Admob for showing ads. Please read their Privacy policy of Google In App
					Purchase and Google Admob for details.
				</p>
				<p>
					If you find any security vulnerability that has been inadvertently caused by us,
					or have any question regarding how the app protects your privacy, please send us
					an email and we will surely try to fix it/help you.
				</p>
			</div>

			<div class="policy-section">
				<h2>Moon Phases Widget / WAM Swell Adriatic Widget / WAM Swell Mediterranean Widget</h2>
				<p>
					App is not programmed to collect any personally identifiable information.
					All data (app preferences like theme, etc.) created by you is stored on your
					device only, and can be simply erased by clearing the app's data or uninstalling it.
				</p>
				<p>
					Only data that could be gathered is by Google (paying for in app product) or
					Google Admob for showing ads. Please read their Privacy policy of Google In App
					Purchase and Google Admob for details.
				</p>
				<p>
					If you find any security vulnerability that has been inadvertently caused by us,
					or have any question regarding how the app protects your privacy, please send us
					an email and we will surely try to fix it/help you.
				</p>
			</div>

			<p>
				Contact: <a href="mailto:mohortus@gmail.com">mohortus@gmail.com</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
