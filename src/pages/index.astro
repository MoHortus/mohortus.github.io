---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { url } from '../utils/paths';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				text-align: center;
				padding: 4rem 0 3rem;
			}
			.hero h1 {
				font-size: 3rem;
				margin-bottom: 0.5rem;
			}
			.hero .tagline {
				font-size: 1.2rem;
				color: var(--color-text-muted);
				margin-bottom: 2rem;
				font-family: var(--font-sans);
				text-transform: uppercase;
				letter-spacing: 0.1em;
			}
			.hero p {
				font-size: 1.05rem;
				line-height: 1.7;
				max-width: 620px;
				margin: 0 auto 2rem;
				color: var(--color-text-muted);
			}
			.cards {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 2rem;
				margin-top: 3rem;
			}
			.card {
				border: 1px solid var(--color-border);
				border-radius: 12px;
				overflow: hidden;
				transition: box-shadow 0.2s, transform 0.2s;
				text-decoration: none;
				color: inherit;
				display: block;
				background: var(--color-bg);
			}
			.card:hover {
				box-shadow: var(--shadow-lg);
				transform: translateY(-3px);
				border-color: var(--color-accent);
			}
			.card img {
				width: 100%;
				height: 200px;
				object-fit: cover;
			}
			.card-body {
				padding: 1.5rem;
			}
			.card-body h2 {
				margin: 0 0 0.5rem;
				font-size: 1.3rem;
				border-bottom: none;
				padding-bottom: 0;
			}
			.card-body p {
				color: var(--color-text-muted);
				font-size: 0.95rem;
				line-height: 1.6;
				margin: 0;
			}
			.card-link {
				display: inline-block;
				margin-top: 1rem;
				font-weight: 600;
				color: var(--color-accent);
				font-size: 0.9rem;
			}
			@media (max-width: 640px) {
				.hero h1 { font-size: 2rem; }
				.cards { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>MoHortus</h1>
				<p class="tagline">Apps and science</p>
				<p>You can find currently published apps on <a href="https://play.google.com/store/apps/developer?id=MoHortus" target="_blank" rel="noopener noreferrer">Google Play</a>.</p>
			</section>

			<hr style="border-top: 1px solid var(--color-border); margin: 0 0 3rem;" />

			<div class="cards">
				<a href={url('/moon-phases')} class="card">
					<img src="/images/app-moon-image2.jpg" alt="Moon Phases Widget App screenshot" />
					<div class="card-body">
						<h2>Moon Phases Widget App</h2>
						<p>Android widget app showing the current moon phase on your home screen. Available on Google Play.</p>
						<span class="card-link">Learn more →</span>
					</div>
				</a>

				<a href={url('/research')} class="card">
					<div class="card-body" style="padding: 2rem;">
						<h2>Research — Wave Height</h2>
						<p>Wave height forecasting and measurement in The Gulf of Trieste. Comparing WAM numerical model data with buoy measurements.</p>
						<span class="card-link">Learn more →</span>
					</div>
				</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
